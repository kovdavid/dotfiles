#!/usr/bin/env bash

exec > >(tee -a /tmp/$(basename $0)) 2>&1

while read SESSION_DATA; do
	SESSION_ID=$(echo "$SESSION_DATA" | cut -f1 -d ' ')
	SESSION_NAME=$(echo "$SESSION_DATA" | cut -f1 -d ' ' --complement)
	SESSION_PATH=$(tmux display-message -p -t $SESSION_ID "#{session_path}")

	echo "SESSION: $SESSION_ID $SESSION_NAME ||> $SESSION_PATH"

	while read WINDOW_DATA; do
		WINDOW_ID=$(echo "$WINDOW_DATA" | cut -f1 -d ' ')
		WINDOW_NAME=$(echo "$WINDOW_DATA" | cut -f2 -d ' ')
		WINDOW_PATH=$(echo "$WINDOW_DATA" | cut -f3 -d ' ')

		echo -e "\tWINDOW $WINDOW_ID $WINDOW_NAME ||> $WINDOW_PATH"
	done <<< "$(tmux list-windows -t $SESSION_ID -F '#{window_id} #{window_name} #{@window_path}')"
done <<< "$(tmux list-sessions -F '#{session_id} #{session_name}')"
