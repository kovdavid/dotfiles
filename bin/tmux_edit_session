#!/usr/bin/env bash

exec > >(tee -a /tmp/$(basename $0)) 2>&1

CURRENT_SESSION_ID=$(tmux display-message -p '#{session_id}')
SESSION_ID=${1:-$CURRENT_SESSION_ID}
SESSION=$(tmux display-message -p -t $SESSION_ID "#{session_id} #{session_name}")
CD_DIR=$(tmux display-message -p -t $SESSION_ID "#{session_path}")

echo "Editing session $SESSION"

read -p "Default directory: " -e -i "$CD_DIR" CD_DIR

if [ "$CD_DIR" == "pwd" ] ; then
    CD_DIR=$(tmux display-message -t{last} -p '#{pane_current_path}')
fi

tmux attach-session -t $SESSION_ID -c "$CD_DIR" \; detach-client
